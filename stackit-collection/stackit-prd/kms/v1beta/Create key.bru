meta {
  name: Create key
  type: http
  seq: 6
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1beta/projects/{{projectId}}/regions/{{regionId}}/keyrings/{{keyRingId}}/keys
  body: json
  auth: inherit
}

body:json {
  {
    "access_scope": "PUBLIC",
    "algorithm": "aes_256_gcm",
    "backend": "software",
    "description": "",
    "displayName": "",
    "importOnly": false,
    "protection": "software",
    "purpose": "symmetric_encrypt_decrypt"
  }
}
