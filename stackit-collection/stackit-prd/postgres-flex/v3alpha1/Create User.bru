meta {
  name: Create User
  type: http
  seq: 21
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/users
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}

body:json {
  {
    "name": "myUser",
    "roles": [
      "createdb",
      "login"
    ]
  }
}
