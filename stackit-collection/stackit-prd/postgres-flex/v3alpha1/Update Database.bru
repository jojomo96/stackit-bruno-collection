meta {
  name: Update Database
  type: http
  seq: 17
}

auth {
  mode: inherit
}

put {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/databases/:databaseId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  databaseId: {{databaseId}}
}

body:json {
  {
    "name": "MyDatabase",
    "owner": "MyUser"
  }
}
