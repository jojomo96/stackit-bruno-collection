meta {
  name: List Users
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/users
  body: none
  auth: inherit
}

params:query {
  page: 1
  size: 10
  ~sort: id.asc
  ~sort: id.desc
  ~sort: name.desc
  ~sort: name.asc
  ~sort: status.desc
  ~sort: status.asc
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}
