meta {
  name: Update User
  type: http
  seq: 25
}

put {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/users/:userId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  userId: {{userId}}
}

body:json {
  {
    "name": "myUser",
    "roles": [
      "createdb",
      "login"
    ]
  }
}
