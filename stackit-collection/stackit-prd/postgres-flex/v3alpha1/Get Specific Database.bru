meta {
  name: Get Specific Database
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/databases/:databaseId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  databaseId: {{databaseId}}
}
