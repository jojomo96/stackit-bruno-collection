meta {
  name: Update Backup Schedule
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/backups
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
}

body:json {
  {
    "backupSchedule": "6 6 * * *"
  }
}
