meta {
  name: Create Instance
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
}

body:json {
  {
    "acl": {
      "items": [
        "0.0.0.0/0"
      ]
    },
    "backupSchedule": "6 6 * * *",
    "flavorId": "1.1",
    "labels": {},
    "name": "",
    "options": {},
    "replicas": 3,
    "storage": {
      "class": "",
      "size": 10
    },
    "version": "1.0"
  }
}
