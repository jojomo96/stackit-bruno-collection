meta {
  name: Delete Database
  type: http
  seq: 14
}

delete {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances/:instanceId/databases/:databaseId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  databaseId: {{databaseId}}
}
