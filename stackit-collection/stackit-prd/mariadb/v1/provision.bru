meta {
  name: provision
  type: http
  seq: 2
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
}

body:json {
  {
    "instanceName": "",
    "parameters": {
      "enable_monitoring": false,
      "graphite": "yourspace.your-graphite-endpoint.com:12345",
      "max_disk_threshold": 90,
      "metrics_frequency": 0,
      "metrics_prefix": "my-prefix",
      "monitoring_instance_id": "",
      "sgw_acl": "0.0.0.0/0",
      "syslog": [
        "logs4.your-syslog-endpoint.com:54321"
      ]
    },
    "planId": ""
  }
}
