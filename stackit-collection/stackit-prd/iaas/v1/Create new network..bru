meta {
  name: Create new network.
  type: http
  seq: 51
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/networks
  body: json
  auth: inherit
}

body:json {
  {
    "addressFamily": {
      "ipv4": {
        "nameservers": [
          "10.1.2.10"
        ],
        "prefix": "10.0.3.0/25"
      }
    },
    "name": "My Network"
  }
}
