meta {
  name: Create new network range in a network area.
  type: http
  seq: 14
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/organizations/:organizationId/network-areas/:areaId/network-ranges
  body: json
  auth: inherit
}

body:json {
  {
    "ipv4": [
      {
        "prefix": "10.1.2.0/24"
      }
    ]
  }
}
