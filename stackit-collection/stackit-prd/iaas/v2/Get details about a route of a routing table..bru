meta {
  name: Get details about a route of a routing table.
  type: http
  seq: 35
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2/organizations/{{organizationId}}/network-areas/{{areaId}}/regions/{{region}}/routing-tables/{{routingTableId}}/routes/{{routeId}}
  body: none
  auth: inherit
}
