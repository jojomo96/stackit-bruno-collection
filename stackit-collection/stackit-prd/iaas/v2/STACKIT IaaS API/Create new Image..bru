meta {
  name: Create new Image.
  type: http
  seq: 50
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/images
  body: json
  auth: inherit
}

body:json {
  {
    "active": true,
    "diskFormat": "qcow2",
    "labels": {
      "key": "value"
    },
    "minDiskSize": 10,
    "minRam": 1,
    "name": "niceImage",
    "protected": false
  }
}
