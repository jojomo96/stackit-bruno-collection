meta {
  name: Update a region for a network area.
  type: http
  seq: 16
}

patch {
  url: {{baseUrl}}/v2beta1/organizations/:organizationId/network-areas/:areaId/regions/:region
  body: json
  auth: inherit
}

body:json {
  {
    "ipv4": {
      "defaultNameservers": [
        "10.1.2.10"
      ],
      "defaultPrefixLen": 24,
      "maxPrefixLen": 29,
      "minPrefixLen": 24
    }
  }
}
