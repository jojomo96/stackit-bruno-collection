meta {
  name: Create a new affinity group in a project.
  type: http
  seq: 40
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2beta1/projects/{{projectId}}/regions/{{region}}/affinity-groups
  body: json
  auth: inherit
}

body:json {
  {
    "name": "MyAffinityGroup",
    "policy": "anti-affinity"
  }
}
