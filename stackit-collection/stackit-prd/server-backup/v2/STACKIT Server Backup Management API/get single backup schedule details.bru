meta {
  name: get single backup schedule details
  type: http
  seq: 5
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/servers/:serverId/backup-schedules/:backupScheduleId
  body: none
  auth: inherit
}

params:path {
  projectId: 
  serverId: 
  region: 
  backupScheduleId: 
}
