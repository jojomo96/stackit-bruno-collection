meta {
  name: GetCommandTemplate
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/v2beta/projects/:projectId/regions/:region/servers/:serverId/command-templates/:commandTemplateName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  commandTemplateName: {{commandTemplateName}}
  region: {{region}}
}
