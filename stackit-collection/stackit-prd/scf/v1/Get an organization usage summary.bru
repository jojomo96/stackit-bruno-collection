meta {
  name: Get an organization usage summary
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId/usage_summary
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
}
