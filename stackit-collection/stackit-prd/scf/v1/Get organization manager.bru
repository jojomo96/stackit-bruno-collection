meta {
  name: Get organization manager
  type: http
  seq: 7
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId/organization_manager
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
}
