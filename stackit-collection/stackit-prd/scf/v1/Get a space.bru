meta {
  name: Get a space
  type: http
  seq: 16
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId/spaces/:spaceId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
  spaceId: {{spaceId}}
}
