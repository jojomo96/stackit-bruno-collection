meta {
  name: Get an organization quota
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId/quotas/:quotaId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
  quotaId: {{quotaId}}
}
