meta {
  name: Update organization
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
}

body:json {
  {
    "name": "organization0",
    "suspended": false
  }
}
