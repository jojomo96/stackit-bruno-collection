meta {
  name: Get an organization
  type: http
  seq: 4
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
}
