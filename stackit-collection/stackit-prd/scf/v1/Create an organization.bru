meta {
  name: Create an organization
  type: http
  seq: 2
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
}

body:json {
  {
    "name": "my-org",
    "platformId": "00000000-0000-0000-0000-000000000000"
  }
}
