meta {
  name: List organization quotas on a platform
  type: http
  seq: 22
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/platforms/:platformId/quotas
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  platformId: {{platformId}}
}
