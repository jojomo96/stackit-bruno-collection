meta {
  name: List organization quotas
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/organizations/:organizationId/quotas
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  organizationId: {{organizationId}}
}
