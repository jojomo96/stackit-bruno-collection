meta {
  name: get latest backup information for provided instanceId
  type: http
  seq: 6
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/backups
  body: none
  auth: inherit
}

params:path {
  instanceId: {{instanceId}}
  projectId: {{projectId}}
}
