meta {
  name: Update credentials for observability in a project.
  type: http
  seq: 5
}

auth {
  mode: inherit
}

put {
  url: {{baseUrl}}/v2/projects/{{projectId}}/regions/{{region}}/credentials/{{credentialsRef}}
  body: json
  auth: inherit
}

params:path {
  projectId: 
  region: 
  credentialsRef: 
}

body:json {
  {
    "displayName": "my-metrics-credential",
    "password": "",
    "username": ""
  }
}
