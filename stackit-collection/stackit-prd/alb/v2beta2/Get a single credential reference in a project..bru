meta {
  name: Get a single credential reference in a project.
  type: http
  seq: 4
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2beta2/projects/{{projectId}}/regions/{{region}}/credentials/{{credentialsRef}}
  body: none
  auth: inherit
}

params:path {
  projectId: 
  region: 
  credentialsRef: 
}
