meta {
  name: get update service details
  type: http
  seq: 2
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/servers/:serverId/service
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  region: {{region}}
}
