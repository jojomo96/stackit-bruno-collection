meta {
  name: create update
  type: http
  seq: 10
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/servers/:serverId/updates
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  region: {{region}}
}

body:json {
  {
    "backupBeforeUpdate": false,
    "maintenanceWindow": 0
  }
}
