meta {
  name: get single update schedule details
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/servers/:serverId/update-schedules/:scheduleId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  scheduleId: {{scheduleId}}
  region: {{region}}
}
