meta {
  name: update update schedule
  type: http
  seq: 10
}

auth {
  mode: inherit
}

put {
  url: {{baseUrl}}/v1/projects/{{projectId}}/servers/{{serverId}}/update-schedules/{{scheduleId}}
  body: json
  auth: inherit
}

params:path {
  projectId: 
  serverId: 
  scheduleId: 
}

body:json {
  {
    "enabled": true,
    "maintenanceWindow": 0,
    "name": "Daily Schedule",
    "rrule": "DTSTART;TZID=Europe/Sofia:20200803T023000 RRULE:FREQ=DAILY;INTERVAL=1"
  }
}
