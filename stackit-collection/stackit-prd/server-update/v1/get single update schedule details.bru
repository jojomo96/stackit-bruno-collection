meta {
  name: get single update schedule details
  type: http
  seq: 9
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/servers/:serverId/update-schedules/:scheduleId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  scheduleId: {{scheduleId}}
}
