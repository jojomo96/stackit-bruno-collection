meta {
  name: delete update schedule
  type: http
  seq: 8
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v1/projects/:projectId/servers/:serverId/update-schedules/:scheduleId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  serverId: {{serverId}}
  scheduleId: {{scheduleId}}
}
