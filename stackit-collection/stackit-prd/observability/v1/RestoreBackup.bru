meta {
  name: RestoreBackup
  type: http
  seq: 42
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/backup-restores/:backupDate
  body: none
  auth: inherit
}

params:query {
  restoreTarget: alertConfig
  ~restoreTarget: alertRules
  ~restoreTarget: scrapeConfig
  ~restoreTarget: grafana
}

params:path {
  backupDate: {{backupDate}}
  instanceId: {{instanceId}}
  projectId: {{projectId}}
}
