meta {
  name: GetAlertRecord
  type: http
  seq: 40
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/alertgroups/:groupName/records/:alertRecord
  body: none
  auth: inherit
}

params:path {
  alertRecord: {{alertRecord}}
  groupName: {{groupName}}
  instanceId: {{instanceId}}
  projectId: {{projectId}}
}
