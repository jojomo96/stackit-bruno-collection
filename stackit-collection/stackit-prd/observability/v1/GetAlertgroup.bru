meta {
  name: GetAlertgroup
  type: http
  seq: 26
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/alertgroups/:groupName
  body: none
  auth: inherit
}

params:path {
  groupName: {{groupName}}
  instanceId: {{instanceId}}
  projectId: {{projectId}}
}
