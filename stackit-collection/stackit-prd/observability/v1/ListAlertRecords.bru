meta {
  name: ListAlertRecords
  type: http
  seq: 36
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/alertgroups/:groupName/records
  body: none
  auth: inherit
}

params:path {
  groupName: {{groupName}}
  instanceId: {{instanceId}}
  projectId: {{projectId}}
}
