}

body:json {
  [
    {
      "interval": "60s",
      "name": "string",
      "rules": [
        {
          "alert": "string",
          "annotations": {},
          "expr": "string",
          "for": "0s",
          "labels": {}
        },
        {
          "expr": "string",
          "labels": {},
          "record": "string"
        }
      ]
    }
  ]
}
