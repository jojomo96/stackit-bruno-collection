meta {
  name: Delete Share
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/v1beta/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/shares/:shareId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
  shareId: {{shareId}}
}
