meta {
  name: Get Resource Pool Snapshot
  type: http
  seq: 14
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1beta/projects/{{projectId}}/regions/{{region}}/resourcePools/{{resourcePoolId}}/snapshots/{{snapshotName}}
  body: none
  auth: inherit
}

params:path {
  projectId: 
  region: 
  resourcePoolId: 
  snapshotName: 
}
