meta {
  name: List Resource Pool Snapshots
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/v1beta/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/snapshots
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
}
