meta {
  name: Create Share
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/v1beta/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/shares
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
}

body:json {
  {
    "exportPolicyName": "",
    "labels": {},
    "name": "",
    "spaceHardLimitGigabytes": 0
  }
}
