meta {
  name: Delete Resource Pool Snapshot
  type: http
  seq: 13
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v1beta/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/snapshots/:snapshotName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
  snapshotName: {{snapshotName}}
}
