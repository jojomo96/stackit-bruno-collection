meta {
  name: Create Resource Pool Snapshot
  type: http
  seq: 12
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/snapshots
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
}

body:json {
  {
    "comment": "",
    "name": ""
  }
}
