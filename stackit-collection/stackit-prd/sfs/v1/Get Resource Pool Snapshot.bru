meta {
  name: Get Resource Pool Snapshot
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/snapshots/:snapshotName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
  snapshotName: {{snapshotName}}
}
