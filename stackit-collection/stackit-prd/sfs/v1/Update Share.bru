meta {
  name: Update Share
  type: http
  seq: 10
}

auth {
  mode: inherit
}

patch {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/resourcePools/:resourcePoolId/shares/:shareId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
  shareId: {{shareId}}
}

body:json {
  {
    "exportPolicyName": "",
    "labels": {},
    "spaceHardLimitGigabytes": 0
  }
}
