  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  policyId: {{policyId}}
}

body:json {
  {
    "labels": {},
    "rules": [
      {
        "description": "",
        "ipAcl": [],
        "order": 0,
        "readOnly": false,
        "setUuid": false,
        "superUser": false
      }
    ]
  }
}
