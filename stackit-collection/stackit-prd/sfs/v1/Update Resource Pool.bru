meta {
  name: Update Resource Pool
  type: http
  seq: 5
}

auth {
  mode: inherit
}

patch {
  url: {{baseUrl}}/v1/projects/:projectId/regions/:region/resourcePools/:resourcePoolId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  resourcePoolId: {{resourcePoolId}}
}

body:json {
  {
    "ipAcl": [],
    "labels": {},
    "performanceClass": "",
    "sizeGigabytes": 0,
    "snapshotsAreVisible": false
  }
}
