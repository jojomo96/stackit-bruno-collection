meta {
  name: Export all records in a single zone
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/zones/:zoneId/export
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  zoneId: {{zoneId}}
}

body:json {
  {
    "exportAsFQDN": true,
    "format": "csv"
  }
}
