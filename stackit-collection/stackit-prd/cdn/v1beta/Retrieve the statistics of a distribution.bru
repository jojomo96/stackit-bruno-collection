meta {
  name: Retrieve the statistics of a distribution
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/v1beta/projects/:projectId/distributions/:distributionId/statistics
  body: none
  auth: inherit
}

params:query {
  from: 
  ~to: 
  ~interval: hourly
  ~interval: daily
  ~interval: monthly
  ~interval: yearly
}

params:path {
  projectId: {{projectId}}
  distributionId: {{distributionId}}
}
