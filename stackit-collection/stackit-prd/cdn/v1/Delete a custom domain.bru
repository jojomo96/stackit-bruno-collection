meta {
  name: Delete a custom domain
  type: http
  seq: 9
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v1/projects/:projectId/distributions/:distributionId/customDomains/:domain
  body: none
  auth: inherit
}

params:query {
  ~intentId: 
}

params:path {
  projectId: {{projectId}}
  distributionId: {{distributionId}}
  domain: {{domain}}
}
