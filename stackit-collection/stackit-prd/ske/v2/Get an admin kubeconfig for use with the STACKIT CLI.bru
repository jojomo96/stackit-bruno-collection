meta {
  name: Get an admin kubeconfig for use with the STACKIT CLI
  type: http
  seq: 9
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/clusters/:clusterName/kubeconfig/login
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  clusterName: {{clusterName}}
}
