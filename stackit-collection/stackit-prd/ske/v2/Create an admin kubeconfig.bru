meta {
  name: Create an admin kubeconfig
  type: http
  seq: 7
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/clusters/:clusterName/kubeconfig
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  clusterName: {{clusterName}}
}

body:json {
  {
    "expirationSeconds": ""
  }
}
