meta {
  name: Get a kubeconfig to authenticate via IDP for use with the STACKIT CLI
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/clusters/:clusterName/kubeconfig/idp
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  clusterName: {{clusterName}}
}
