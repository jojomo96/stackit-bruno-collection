meta {
  name: Update credentials for observability in a project.
  type: http
  seq: 9
}

auth {
  mode: inherit
}

put {
  url: {{baseUrl}}/v1/projects/:projectId/credentials/:credentialsRef
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  credentialsRef: {{credentialsRef}}
}

body:json {
  {
    "displayName": "my-metrics-credential",
    "password": "",
    "username": ""
  }
}
