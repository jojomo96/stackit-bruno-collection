meta {
  name: Get a single credential reference in a project.
  type: http
  seq: 8
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/credentials/:credentialsRef
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  credentialsRef: {{credentialsRef}}
}
