meta {
  name: Create credentials for observability of the Load Balancer
  type: http
  seq: 2
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/credentials
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
}

headers {
  ~X-Request-ID: 
}

body:json {
  {
    "displayName": "my-metrics-credential",
    "password": "",
    "username": ""
  }
}
