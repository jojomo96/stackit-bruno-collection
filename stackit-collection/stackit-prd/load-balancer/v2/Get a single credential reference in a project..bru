meta {
  name: Get a single credential reference in a project.
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/credentials/:credentialsRef
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  credentialsRef: {{credentialsRef}}
}
