meta {
  name: Delete a single credential in a project.
  type: http
  seq: 3
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v2/projects/{{projectId}}/regions/{{region}}/credentials/{{credentialsRef}}
  body: none
  auth: inherit
}

params:path {
  projectId: 
  region: 
  credentialsRef: 
}
