meta {
  name: Remove members from a resource
  type: http
  seq: 5
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v2/:resourceId/members/remove
  body: json
  auth: inherit
}

params:path {
  resourceId: {{resourceId}}
}

body:json {
  {
    "forceRemove": false,
    "members": [
      {
        "role": "owner",
        "subject": "user@mail.schwarz"
      }
    ],
    "resourceType": "organization"
  }
}
