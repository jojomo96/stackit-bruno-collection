meta {
  name: Create Access Token
  type: http
  seq: 8
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/{{projectId}}/regions/{{regionId}}/instances/{{instanceId}}/access-tokens
  body: json
  auth: inherit
}

body:json {
  {
    "description": "",
    "displayName": "",
    "lifetime": 0,
    "permissions": [
      "read",
      "write"
    ]
  }
}
