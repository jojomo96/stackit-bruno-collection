meta {
  name: Gets the status for a specific connection.
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/v1alpha1/projects/:projectId/regions/:region/gateways/:gatewayId/connections/:connectionId/status
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  region: eu02
  gatewayId: {{gatewayId}}
  connectionId: {{connectionId}}
}
