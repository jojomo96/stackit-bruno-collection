meta {
  name: List Databases
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/databases
  body: none
  auth: inherit
}

params:query {
  page: 1
  size: 10
  ~sort: created_at.desc
  ~sort: created_at.asc
  ~sort: database_id.desc
  ~sort: database_id.asc
  ~sort: database_name.desc
  ~sort: database_name.asc
  ~sort: database_owner.desc
  ~sort: database_owner.asc
  ~sort: index.asc
  ~sort: index.desc
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}
