meta {
  name: Get database collation list
  type: http
  seq: 12
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/collations
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}
