meta {
  name: Get Database
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/v3alpha1/projects/:projectId/regions/:region/instances/:instanceId/databases/:databaseName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  databaseName: {{databaseName}}
}
