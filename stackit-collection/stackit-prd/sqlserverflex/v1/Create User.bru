meta {
  name: Create User
  type: http
  seq: 22
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/users
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
}

body:json {
  {
    "default_database": "",
    "roles": [],
    "username": ""
  }
}
