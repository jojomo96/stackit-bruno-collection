meta {
  name: Get specific Database
  type: http
  seq: 17
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/databases/:databaseName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  databaseName: {{databaseName}}
}
