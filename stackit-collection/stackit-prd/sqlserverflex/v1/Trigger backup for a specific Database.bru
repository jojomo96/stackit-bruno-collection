meta {
  name: Trigger backup for a specific Database
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/backups/databases/:databaseName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  databaseName: {{databaseName}}
}
