meta {
  name: List Users
  type: http
  seq: 22
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/users
  body: none
  auth: inherit
}

params:query {
  page: 1
  size: 10
  ~sort: id.asc
  ~sort: id.desc
  ~sort: index.desc
  ~sort: index.asc
  ~sort: name.desc
  ~sort: name.asc
  ~sort: status.desc
  ~sort: status.asc
}

params:path {
  projectId: 
  region: eu01
  instanceId: 
}
