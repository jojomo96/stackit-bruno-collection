meta {
  name: Trigger backup for a specific Database
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/backups/databases/:databaseName
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  databaseName: {{databaseName}}
}
