meta {
  name: Create Database
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/databases
  body: json
  auth: inherit
}

params:path {
  projectId: 
  region: eu01
  instanceId: 
}

body:json {
  {
    "collation": "Albanian_BIN",
    "compatibility": 160,
    "name": "MyDatabase",
    "owner": "MyUser"
  }
}
