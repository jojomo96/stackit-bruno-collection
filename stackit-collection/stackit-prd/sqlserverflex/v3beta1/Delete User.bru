meta {
  name: Delete User
  type: http
  seq: 24
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/users/:userId
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
  userId: {{userId}}
}
