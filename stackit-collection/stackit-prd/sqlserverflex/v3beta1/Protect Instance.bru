meta {
  name: Protect Instance
  type: http
  seq: 18
}

post {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/protections
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}

body:json {
  {
    "isDeletable": true
  }
}
