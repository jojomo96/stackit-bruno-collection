meta {
  name: Create User
  type: http
  seq: 23
}

post {
  url: {{baseUrl}}/v3beta1/projects/:projectId/regions/:region/instances/:instanceId/users
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: eu01
  instanceId: {{instanceId}}
}

body:json {
  {
    "default_database": "tempdb",
    "roles": [
      "##STACKIT_LoginManager##",
      "##STACKIT_DatabaseManager##"
    ],
    "username": "myUser"
  }
}
