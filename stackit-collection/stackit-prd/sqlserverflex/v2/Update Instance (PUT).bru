meta {
  name: Update Instance (PUT)
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances/:instanceId
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  region: eu01
  region: eu02
}

body:json {
  {
    "acl": {},
    "backupSchedule": "6 6 * * *",
    "flavorId": "4.16-Single",
    "labels": {},
    "name": "test-instance",
    "version": "2022"
  }
}
