meta {
  name: Get database compatibility list
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances/:instanceId/compatibility
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  region: eu01
  region: eu02
}
