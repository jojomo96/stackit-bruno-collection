meta {
  name: Create User
  type: http
  seq: 18
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/users
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
}

body:json {
  {
    "database": "",
    "roles": [
      "readAnyDatabase"
    ],
    "username": ""
  }
}
