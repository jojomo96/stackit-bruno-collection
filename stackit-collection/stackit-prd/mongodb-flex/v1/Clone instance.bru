meta {
  name: Clone instance
  type: http
  seq: 13
}

auth {
  mode: inherit
}

post {
  url: {{baseUrl}}/v1/projects/:projectId/instances/:instanceId/clone
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
}

body:json {
  {
    "instanceId": "",
    "timestamp": ""
  }
}
