meta {
  name: Get suggested indexes
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances/:instanceId/advisor/suggested-indexes
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  region: eu01
  region: eu02
}
