meta {
  name: Create User
  type: http
  seq: 18
}

post {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/instances/:instanceId/users
  body: json
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  instanceId: {{instanceId}}
  region: eu01
  region: eu02
}

body:json {
  {
    "database": "",
    "roles": [
      "readAnyDatabase"
    ],
    "username": ""
  }
}
