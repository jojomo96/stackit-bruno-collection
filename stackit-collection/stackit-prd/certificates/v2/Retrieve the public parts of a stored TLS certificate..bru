meta {
  name: Retrieve the public parts of a stored TLS certificate.
  type: http
  seq: 4
}

auth {
  mode: inherit
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/certificates/:id
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  id: {{id}}
}
