meta {
  name: Retrieve the list of TLS certificate stored in a project.
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v2/projects/:projectId/regions/:region/certificates
  body: none
  auth: inherit
}

params:query {
  ~pageSize: 
  ~pageId: 
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
}
