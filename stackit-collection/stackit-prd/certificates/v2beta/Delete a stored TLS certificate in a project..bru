meta {
  name: Delete a stored TLS certificate in a project.
  type: http
  seq: 3
}

auth {
  mode: inherit
}

delete {
  url: {{baseUrl}}/v2beta/projects/:projectId/regions/:region/certificates/:id
  body: none
  auth: inherit
}

params:path {
  projectId: {{projectId}}
  region: {{region}}
  id: {{id}}
}
